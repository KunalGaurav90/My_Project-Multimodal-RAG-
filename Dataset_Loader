if __name__ == '__main__':
    import sys
    import subprocess
    import os
    import inspect

    # -----------------------------------------------------------------
    # 1. Install open_clip_torch if missing
    # -----------------------------------------------------------------
    try:
        import open_clip
    except ImportError:
        print("📦 Installing open_clip_torch...")
        subprocess.check_call([sys.executable, "-m", "pip", "install", "open_clip_torch"])
        import open_clip

    # -----------------------------------------------------------------
    # 2. Monkey‑patch 1: fake the 'clvp' module to avoid import error
    # -----------------------------------------------------------------
    from types import ModuleType
    if 'transformers.models.clvp' not in sys.modules:
        sys.modules['transformers.models.clvp'] = ModuleType('clvp')

    # -----------------------------------------------------------------
    # 3. Monkey‑patch 2: dynamically filter unknown kwargs for CLIPTextCfg
    #    (this automatically ignores hf_proj_type, hf_pooler_type, etc.)
    #    Guarded so re-running this cell doesn't wrap the already-
    #    patched __init__ again (that caused RecursionError).
    # -----------------------------------------------------------------
    from open_clip import CLIPTextCfg

    if not getattr(CLIPTextCfg.__init__, '_is_patched', False):
        _orig_init = CLIPTextCfg.__init__
        _sig = inspect.signature(_orig_init)

        def _patched_init(self, **kwargs):
            # Keep only arguments that are accepted by the original __init__
            filtered = {k: v for k, v in kwargs.items() if k in _sig.parameters}
            _orig_init(self, **filtered)

        _patched_init._is_patched = True
        CLIPTextCfg.__init__ = _patched_init

    # -----------------------------------------------------------------
    # 4. Monkey-patch 3: strip 'position_ids' from checkpoint state_dict
    #    (newer transformers register position_ids as a non-persistent
    #    buffer, so old checkpoints that saved it trigger a spurious
    #    "Unexpected key(s) in state_dict: text.transformer.embeddings.
    #    position_ids" RuntimeError on load_state_dict with strict=True)
    # -----------------------------------------------------------------
    import open_clip.factory as _factory

    _orig_load_state_dict_fn = _factory.load_state_dict

    def _patched_load_state_dict_fn(checkpoint_path, map_location='cpu'):
        sd = _orig_load_state_dict_fn(checkpoint_path, map_location)
        sd = {k: v for k, v in sd.items() if 'position_ids' not in k}
        return sd

    _factory.load_state_dict = _patched_load_state_dict_fn

    # -----------------------------------------------------------------
    # 5. Patch missing utility functions (just in case)
    # -----------------------------------------------------------------
    try:
        from transformers.utils import is_torch_mlu_available
    except ImportError:
        import transformers.utils
        transformers.utils.is_torch_mlu_available = lambda: False

