# CUSTOM DATASET CLASS FOR MERGED_REPORTS.JSON
# ============================================================
import json
import os
import torch
from torch.utils.data import Dataset
from PIL import Image
import numpy as np

class MedicalReportDataset(Dataset):
    def __init__(self, json_path, images_dir, preprocess, tokenizer, max_text_len=256):
        self.json_path = json_path
        self.images_dir = images_dir
        self.preprocess = preprocess
        self.tokenizer = tokenizer
        self.max_text_len = max_text_len
        
        with open(json_path, 'r') as f:
            self.data = json.load(f)
        
        self.image_to_idx = {entry.get('image', ''): idx for idx, entry in enumerate(self.data)}
        print(f"✅ Loaded {len(self.data)} medical entries")
        print(f"✅ Found {len(self.image_to_idx)} images mapped")
        
        self.query_fields = ['cause', 'symptom', 'treatment']
        self.context_fields = ['description', 'chunk', 'prevention']
        self.qa_pairs = []
        self._create_qa_pairs()
    
    def _create_qa_pairs(self):
        for idx, entry in enumerate(self.data):
            entity = entry.get('entity', 'Unknown Disease')
            for qf in self.query_fields:
                qtext = entry.get(qf, '')
                if not qtext:
                    continue
                for cf in self.context_fields:
                    ctext = entry.get(cf, '')
                    if not ctext:
                        continue
                    self.qa_pairs.append({
                        'query_field': qf, 'query_text': qtext,
                        'context_field': cf, 'context_text': ctext,
                        'entity': entity, 'image_idx': idx,
                        'image_name': entry.get('image', '')
                    })
        print(f"✅ Created {len(self.qa_pairs)} Q&A pairs")
    
    def __len__(self):
        return len(self.qa_pairs)
    
    def __getitem__(self, idx):
        pair = self.qa_pairs[idx]
        query_prompt = f"{pair['query_field'].upper()}: {pair['query_text']}"
        pos_text = f"{pair['entity']}. {pair['context_text']}"
        
        neg_idx = np.random.randint(0, len(self.data))
        while neg_idx == pair['image_idx']:
            neg_idx = np.random.randint(0, len(self.data))
        neg_entry = self.data[neg_idx]
        neg_text = f"{neg_entry.get('entity', 'Unknown')}. {neg_entry.get('description', '')}"
        
        def tokenize(text):
            # open_clip's HFTokenizer wrapper only accepts `texts` and
            # `context_length` — it does NOT accept the raw HuggingFace
            # kwargs (max_length/truncation/padding/return_tensors).
            # It handles truncation/padding internally and always
            # returns a [batch, seq_len] tensor of input_ids.
            return self.tokenizer([text], context_length=self.max_text_len).squeeze(0)
        query_ids = tokenize(query_prompt)
        pos_ids = tokenize(pos_text)
        neg_ids = tokenize(neg_text)
        
        img_path = os.path.join(self.images_dir, pair['image_name'])
        if not os.path.exists(img_path):
            query_image = torch.zeros(3, 224, 224)
        else:
            try:
                image = Image.open(img_path).convert('RGB')
                query_image = self.preprocess(image)
            except Exception:
                query_image = torch.zeros(3, 224, 224)
        
        return {
            'query_ids': query_ids,
            'query_image': query_image,
            'pos_ids': pos_ids,
            'neg_ids': neg_ids,
        }
    
    def get_entry_info(self, idx):
        if idx >= len(self.data):
            return None
        entry = self.data[idx]
        return {
            'entity': entry.get('entity'),
            'location': entry.get('location'),
            'image': entry.get('image'),
            'description': entry.get('description', '')[:200] + '...',
            'symptoms': entry.get('symptom', '')[:200] + '...',
            'treatment': entry.get('treatment', '')[:200] + '...',
        }


