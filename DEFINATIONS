from open_clip import create_model_from_pretrained, get_tokenizer
import torch.nn as nn
import torch.nn.functional as F

class NTXentLoss(nn.Module):
    def __init__(self, temperature=0.5):
        super().__init__()
        self.temperature = temperature

    def forward(self, anchor, positive, negatives):
        anchor    = F.normalize(anchor, dim=1)
        positive  = F.normalize(positive, dim=1)
        negatives = F.normalize(negatives, dim=2)
        pos_sim   = torch.sum(anchor * positive, dim=1) / self.temperature
        neg_sim   = torch.bmm(negatives, anchor.unsqueeze(2)).squeeze(2) / self.temperature
        logits    = torch.cat([pos_sim.unsqueeze(1), neg_sim], dim=1)
        labels    = torch.zeros(anchor.size(0), dtype=torch.long, device=anchor.device)
        return F.cross_entropy(logits, labels)

class ColBERT(nn.Module):
    def __init__(self):
        super().__init__()
        self.BioCLIP, self.preprocess = create_model_from_pretrained(
            'hf-hub:microsoft/BiomedCLIP-PubMedBERT_256-vit_base_patch16_224'
        )
        self.BioCLIP.eval()
        self.text_linear = nn.Sequential(
            nn.Linear(512, 512), nn.Tanh(), nn.Linear(512, 512)
        )
        self.image_linear = nn.Sequential(
            nn.Linear(512, 512), nn.Tanh(), nn.Linear(512, 512)
        )
        self.criterion = NTXentLoss(temperature=0.5)

    def _encode_text(self, text_ids):
        with torch.no_grad():
            feats = self.BioCLIP.encode_text(text_ids)
        return self.text_linear(feats)

    def _encode_image(self, image_tensor):
        with torch.no_grad():
            feats = self.BioCLIP.encode_image(image_tensor)
        return self.image_linear(feats)

    def forward(self, queries, query_image_input,
                documents, key_image_inputs, device):
        scores = []
        for query, q_img, doc, k_img in zip(
                queries, query_image_input, documents, key_image_inputs):
            q_img = q_img.unsqueeze(0)
            q_text_vec  = self._encode_text(query)
            q_img_vec   = self._encode_image(q_img)
            d_text_vec  = self._encode_text(doc)
            d_img_vec   = self._encode_image(k_img)
            text_score  = torch.matmul(q_text_vec, d_text_vec.T)
            image_score = torch.matmul(q_img_vec,  d_img_vec.T)
            scores.append(0.5 * text_score + 0.5 * image_score)
        return torch.stack(scores)

    def encode_text(self, text_ids):
        return self._encode_text(text_ids)

    def encode_image(self, image_tensor):
        return self._encode_image(image_tensor)

    def cl_loss(self, anchor_image, positive_image, negative_images):
        anchor    = self.BioCLIP.encode_image(anchor_image)
        positive  = self.BioCLIP.encode_image(positive_image)
        negatives = torch.stack([self.BioCLIP.encode_image(n) for n in negative_images])
        return self.criterion(anchor, positive, negatives)

print('✅ ColBERT class defined (BiomedCLIP backbone, 512-D, text+image scoring).')



